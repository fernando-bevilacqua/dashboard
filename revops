    </div>
  </div>
</div>

<div class="cmpbar" id="cmpBar">
  <span class="cplbl cpa">Período A</span><div class="chips" id="cmpAC"></div>
  <span style="color:var(--tx3);font-size:12px;margin:0 4px">vs</span>
  <span class="cplbl cpb">Período B</span><div class="chips" id="cmpBC"></div>
</div>

<main class="main">
  <div class="krow" id="krow"></div>
  <div class="g2">
    <div class="card">
      <div class="ctit">Oportunidades e vendas — evolução mensal</div>
      <div style="position:relative;height:210px"><canvas id="cMain" role="img" aria-label="Evolução mensal"></canvas></div>
    </div>
    <div class="card">
      <div class="ctit">Faturamento mensal</div>
      <div style="position:relative;height:210px"><canvas id="cFat" role="img" aria-label="Faturamento mensal"></canvas></div>
    </div>
  </div>
  <div class="g2">
    <div class="card">
      <div class="ctit">Canais — first touch</div>
      <div style="overflow-x:auto"><table class="tbl" id="ctbl"></table></div>
    </div>
    <div style="display:flex;flex-direction:column;gap:14px">
      <div class="card">
        <div class="ctit">Faturamento por canal</div>
        <div style="position:relative;height:185px"><canvas id="cCan" role="img" aria-label="Faturamento por canal"></canvas></div>
      </div>
      <div class="card">
        <div class="ctit">Top campanhas</div>
        <div id="camps"></div>
      </div>
    </div>
  </div>
</main>

