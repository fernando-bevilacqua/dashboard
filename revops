    '<div style="display:grid;grid-template-columns:1fr 34px 60px 58px;gap:4px;padding-bottom:6px;border-bottom:1px solid var(--bd)">'+
    '<span style="font-size:10px;color:var(--tx3);text-transform:uppercase;letter-spacing:.07em">Campanha</span>'+
    '<span style="font-size:10px;color:var(--tx3);text-align:right">V.</span>'+
    '<span style="font-size:10px;color:var(--tx3);text-align:right">Fat.</span>'+
    '<span style="font-size:10px;color:var(--tx3);text-align:right">Ticket</span></div>'+
    camps.map(c=>`<div class="crow"><span class="cnm2" title="${c.campanha}">${c.campanha}</span><span class="cn">${c.vendas}</span><span class="cn">${fK(c.faturamento)}</span><span class="cn" style="color:var(--gr)">${fK(c.ticket)}</span></div>`).join('');
}

function buildPerChips() {
  const avail=new Set(RAW.records.filter(r=>r.ay===CY).map(r=>r.am));
  const extra=MN.map((m,i)=>{
    const mn=i+1,dis=!avail.has(mn);
    return `<button class="chip per ${dis?'off':''}" onclick="${dis?'':'setPer('+mn+',this)'}">${m}</button>`;
  }).join('');
  document.getElementById('perChips').innerHTML=
    `<button class="chip per on" onclick="setPer('all',this)">Ano todo</button>`+extra;
}

function buildCmpBtns() {
  const months=[];
  [2025,2026].forEach(y=>{
    RAW.records.filter(r=>r.ay===y).map(r=>r.am).filter((v,i,a)=>a.indexOf(v)===i).sort()
    .forEach(m=>months.push({y,m}));
  });
  const mkB=(id,sel,fn)=>{
    document.getElementById(id).innerHTML=months.map(o=>{
      const k=o.y+'-'+o.m,l=MN[o.m-1]+' '+o.y;
      return `<button class="chip per ${sel===k?'on':''}" onclick="${fn}('${k}',this)">${l}</button>`;
    }).join('');
  };
  mkB('cmpAC',cmpA,'setCmpA');mkB('cmpBC',cmpB,'setCmpB');
}

function renderAll() {
  const d=getD();
  const cmpD=cmpMode&&cmpA&&cmpB?getCmpData(cmpB):null;
  const cmpA_d=cmpMode&&cmpA?getCmpData(cmpA):null;
  renderKPIs(d,cmpD);
  renderTable(d);
  renderCharts(d,cmpD);
  renderCamps();
}

// handlers
function setYear(y,btn) {
  CY=y;SP='all';
  document.querySelectorAll('.ybtn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  buildPerChips();renderAll();
}
function setPer(v,btn) {
  SP=v;
  document.querySelectorAll('#perChips .chip').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');renderAll();
}
function toggleOrigem(v,btn) {
  if(v==='all'){SO=[];document.querySelectorAll('#oriChips .chip').forEach(b=>b.classList.remove('on'));btn.classList.add('on');}
  else{
    document.querySelector('#oriChips .chip').classList.remove('on');
    const i=SO.indexOf(v);
    if(i>=0){SO.splice(i,1);btn.classList.remove('on');}else{SO.push(v);btn.classList.add('on');}
    if(!SO.length)document.querySelector('#oriChips .chip').classList.add('on');
  }
  renderAll();
}
function toggleCanal(v,btn) {
  if(v==='all'){SC=[];document.querySelectorAll('#canChips .chip').forEach(b=>b.classList.remove('on'));btn.classList.add('on');}
  else{
    document.querySelector('#canChips .chip').classList.remove('on');
    const i=SC.indexOf(v);
    if(i>=0){SC.splice(i,1);btn.classList.remove('on');}else{SC.push(v);btn.classList.add('on');}
    if(!SC.length)document.querySelector('#canChips .chip').classList.add('on');
  }
  renderAll();
}
function togCmp() {
  cmpMode=!cmpMode;
  document.getElementById('cmpTog').classList.toggle('on',cmpMode);
  document.getElementById('cmpBar').classList.toggle('open',cmpMode);
  if(cmpMode)buildCmpBtns();renderAll();
}
function setCmpA(k,btn) {cmpA=k;document.querySelectorAll('#cmpAC .chip').forEach(b=>b.classList.remove('on'));btn.classList.add('on');renderAll();}
function setCmpB(k,btn) {cmpB=k;document.querySelectorAll('#cmpBC .chip').forEach(b=>b.classList.remove('on'));btn.classList.add('on');renderAll();}

buildPerChips();
renderAll();
</script>
</body>
</html>
