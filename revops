function compute(year, period, origens, canais) {
  let rs = RAW.records.filter(r=>r.ay===year);
  if (period!=='all') rs=rs.filter(r=>r.am===period);
  if (origens.length) rs=rs.filter(r=>origens.includes(r.origem));
  if (canais.length)  rs=rs.filter(r=>canais.includes(r.canal));

  const won = rs.filter(r=>r.won);
  const fat = won.reduce((s,r)=>s+r.fat,0);

  const monthly = MN.map((mes,i)=>{
    const m=i+1;
    const hasData = year===2025||m<=4;
    if(!hasData) return {mes,m,opp:null,won:null,fat:null};
    const base = RAW.records.filter(r=>r.ay===year&&r.am===m
      &&(!origens.length||origens.includes(r.origem))
      &&(!canais.length||canais.includes(r.canal)));
    const wonM = RAW.records.filter(r=>r.cy===year&&r.cm===m&&r.won
      &&(!origens.length||origens.includes(r.origem))
      &&(!canais.length||canals.includes(r.canal)));
    return {mes,m,opp:base.length,won:wonM.length,fat:wonM.reduce((s,r)=>s+r.fat,0)};
  });

  const cmap={};
  rs.forEach(r=>{
    if(!cmap[r.canal])cmap[r.canal]={canal:r.canal,opp:0,won:0,fat:0};
    cmap[r.canal].opp++;
    if(r.won){cmap[r.canal].won++;cmap[r.canal].fat+=r.fat;}
  });
  const cdata=Object.values(cmap).map(c=>{
    return {...c,ticket:c.won?Math.round(c.fat/c.won):0,conv:c.opp?Math.round(c.won/c.opp*1000)/10:0};
  }).sort((a,b)=>b.fat-a.fat);

  return {opp:rs.length,won:won.length,fat,ticket:won.length?Math.round(fat/won.length):0,
           conv:rs.length?Math.round(won.length/rs.length*1000)/10:0,monthly,cdata};
}

// Fix: use separate monthly computation that avoids canals typo
function computeMonthly(year, origens, canais) {
  return MN.map((mes,i)=>{
    const m=i+1;
    const hasData=year===2025||m<=4;
    if(!hasData) return {mes,m,opp:null,won:null,fat:null};
    const base=RAW.records.filter(r=>r.ay===year&&r.am===m
      &&(!origens.length||origens.includes(r.origem))
      &&(!canais.length||canais.includes(r.canal)));
    const wonM=RAW.records.filter(r=>r.cy===year&&r.cm===m&&r.won
      &&(!origens.length||origens.includes(r.origem))
      &&(!canais.length||canais.includes(r.canal)));
    return {mes,m,opp:base.length,won:wonM.length,fat:wonM.reduce((s,r)=>s+r.fat,0)};
  });
}

function getD() {
  const rs=RAW.records.filter(r=>r.ay===CY
    &&(SP==='all'||r.am===SP)
    &&(!SO.length||SO.includes(r.origem))
    &&(!SC.length||SC.includes(r.canal)));
  const won=rs.filter(r=>r.won);
  const fat=won.reduce((s,r)=>s+r.fat,0);
  const cmap={};
  rs.forEach(r=>{
    if(!cmap[r.canal])cmap[r.canal]={canal:r.canal,opp:0,won:0,fat:0};
    cmap[r.canal].opp++;
    if(r.won){cmap[r.canal].won++;cmap[r.canal].fat+=r.fat;}
  });
  const cdata=Object.values(cmap).map(c=>{
    return {...c,ticket:c.won?Math.round(c.fat/c.won):0,conv:c.opp?Math.round(c.won/c.opp*1000)/10:0};
  }).sort((a,b)=>b.fat-a.fat);
  return {opp:rs.length,won:won.length,fat,
    ticket:won.length?Math.round(fat/won.length):0,
    conv:rs.length?Math.round(won.length/rs.length*1000)/10:0,
    monthly:computeMonthly(CY,SO,SC), cdata};
}

function getCmpData(key) {
  if(!key) return null;
  const [y,m]=key.split('-').map(Number);
  const rs=RAW.records.filter(r=>r.ay===y&&r.am===m
    &&(!SO.length||SO.includes(r.origem))
    &&(!SC.length||SC.includes(r.canal)));
  const won=rs.filter(r=>r.won);
  const fat=won.reduce((s,r)=>s+r.fat,0);
  return {opp:rs.length,won:won.length,fat,
    ticket:won.length?Math.round(fat/won.length):0,
    monthly:computeMonthly(y,SO,SC),_year:y,_m:m};
}

