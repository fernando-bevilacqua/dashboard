<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>RevOps Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
:root{
  --bg:#0c0e11;--bg2:#12151a;--bg3:#191d24;--bg4:#1f2430;
  --bd:rgba(255,255,255,.06);--bd2:rgba(255,255,255,.11);
  --tx:#eef0f4;--tx2:#7a8394;--tx3:#454d5c;
  --gr:#4fffb0;--bl:#4f9fff;--or:#ff6b4f;--gd:#ffc94f;--pu:#9d7eff;
  --fn:'DM Sans',sans-serif;--mo:'DM Mono',monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px}
body{background:var(--bg);color:var(--tx);font-family:var(--fn);min-height:100vh}

/* header */
.hdr{display:flex;align-items:center;justify-content:space-between;padding:14px 28px;
  border-bottom:1px solid var(--bd);position:sticky;top:0;background:var(--bg);z-index:200}
.logo{display:flex;align-items:center;gap:9px}
.ldot{width:7px;height:7px;border-radius:50%;background:var(--gr);box-shadow:0 0 7px var(--gr)}
.ltxt{font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--tx2)}
.ytabs{display:flex;gap:4px}
.ybtn{font-family:var(--fn);font-size:12px;font-weight:500;padding:5px 16px;border-radius:6px;
  border:1px solid var(--bd2);cursor:pointer;background:transparent;color:var(--tx2);transition:all .18s}
.ybtn.on{background:var(--gr);color:#0c0e11;border-color:var(--gr)}

/* filter bar */
.fbar{background:var(--bg2);border-bottom:1px solid var(--bd)}
.frow{display:flex;align-items:center;min-height:42px;padding:0 28px;border-bottom:1px solid var(--bd)}
.frow:last-child{border-bottom:none}
.flbl{font-size:10px;font-weight:500;letter-spacing:.09em;text-transform:uppercase;
  color:var(--tx3);white-space:nowrap;margin-right:10px;min-width:52px}
.chips{display:flex;gap:4px;flex-wrap:wrap;padding:6px 0}
.chip{font-family:var(--fn);font-size:11px;font-weight:500;padding:4px 11px;border-radius:20px;
  border:1px solid var(--bd2);cursor:pointer;background:transparent;color:var(--tx2);
  transition:all .15s;white-space:nowrap;display:inline-flex;align-items:center;gap:5px}
.chip:hover{color:var(--tx);border-color:rgba(255,255,255,.2)}
.chip.on{background:var(--bg3);border-color:var(--bd2);color:var(--tx)}
.chip.on.per{background:rgba(79,255,176,.1);border-color:rgba(79,255,176,.28);color:var(--gr)}
.chip.on.ori{background:rgba(157,126,255,.1);border-color:rgba(157,126,255,.28);color:var(--pu)}
.chip.on.can{background:color-mix(in srgb,var(--cc,#888) 12%,transparent);
  border-color:color-mix(in srgb,var(--cc,#888) 45%,transparent);color:var(--cc,var(--tx))}
.chip.off{opacity:.28;cursor:not-allowed}
.cdot-sm{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.cmp-wrap{margin-left:auto;display:flex;align-items:center;gap:8px;padding:6px 0}
.cmplbl{font-size:11px;color:var(--tx2)}
.tog{width:34px;height:18px;background:var(--bg3);border-radius:9px;border:1px solid var(--bd2);
  cursor:pointer;position:relative;transition:background .2s;flex-shrink:0}
.tog.on{background:var(--gr);border-color:var(--gr)}
.tog::after{content:'';position:absolute;width:12px;height:12px;border-radius:50%;
  background:var(--tx3);top:2px;left:2px;transition:all .2s}
.tog.on::after{left:18px;background:#0c0e11}
.cmpbar{display:none;align-items:center;gap:8px;flex-wrap:wrap;padding:8px 28px;
  background:var(--bg2);border-bottom:1px solid var(--bd)}
.cmpbar.open{display:flex}
.cplbl{font-size:10px;font-family:var(--mo);padding:3px 9px;border-radius:4px;font-weight:500}
.cpa{background:rgba(79,255,176,.08);color:var(--gr);border:1px solid rgba(79,255,176,.2)}
.cpb{background:rgba(79,159,255,.08);color:var(--bl);border:1px solid rgba(79,159,255,.2)}

/* main */
.main{padding:20px 28px}
.krow{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;margin-bottom:18px}
.kpi{background:var(--bg2);border:1px solid var(--bd);border-radius:10px;padding:16px 18px;
  position:relative;overflow:hidden}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:1.5px;background:var(--kc,var(--bd))}
.klbl{font-size:10px;color:var(--tx3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px}
.kval{font-size:24px;font-weight:300;color:var(--tx);line-height:1;margin-bottom:5px}
.ksub{font-size:11px;color:var(--tx2);display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.dlt{font-size:10px;font-family:var(--mo);padding:2px 6px;border-radius:3px}
.dup{background:rgba(79,255,176,.1);color:var(--gr)}.ddn{background:rgba(255,107,79,.1);color:var(--or)}

/* grid */
.g2{display:grid;grid-template-columns:minmax(0,1.55fr) minmax(0,1fr);gap:14px;margin-bottom:14px}
.g22{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:14px}
.card{background:var(--bg2);border:1px solid var(--bd);border-radius:10px;padding:18px 20px}
.ctit{font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:.09em;color:var(--tx3);margin-bottom:14px}

/* table */
.tbl{width:100%;border-collapse:collapse}
.tbl th{font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:.07em;
  color:var(--tx3);padding:0 0 8px;text-align:right}
.tbl th:first-child{text-align:left}
.tbl td{padding:7px 0;border-top:1px solid var(--bd);font-size:12px;color:var(--tx2);text-align:right;vertical-align:middle}
.tbl td:first-child{text-align:left}
.tbl tr:hover td{color:var(--tx)}
.cnm{display:flex;align-items:center;gap:7px}
.cnm span{font-size:12px;font-weight:500;color:var(--tx);max-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.mb{height:3px;background:var(--bg4);border-radius:2px;width:56px}
.mbf{height:100%;border-radius:2px}
.bdg{font-size:10px;font-family:var(--mo);padding:2px 7px;border-radius:4px}
.bhi{background:rgba(79,255,176,.1);color:var(--gr)}
.bmd{background:rgba(79,159,255,.1);color:var(--bl)}
.blo{background:rgba(255,107,79,.1);color:var(--or)}

/* camps */
.crow{display:grid;grid-template-columns:1fr 38px 66px 62px;gap:5px;align-items:center;
  padding:6px 0;border-top:1px solid var(--bd);font-size:12px}
.crow:first-child{border-top:none}
.cnm2{color:var(--tx);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.cn{color:var(--tx2);text-align:right;font-family:var(--mo);font-size:11px}

/* scrollbar */
::-webkit-scrollbar{width:3px;height:3px}
::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:2px}

@keyframes fu{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:none}}
.kpi{animation:fu .32s ease both}
.kpi:nth-child(1){animation-delay:.04s}.kpi:nth-child(2){animation-delay:.08s}
.kpi:nth-child(3){animation-delay:.12s}.kpi:nth-child(4){animation-delay:.16s}
</style>
</head>
<body>

<header class="hdr">
  <div class="logo"><div class="ldot"></div><span class="ltxt">RevOps · Vendas &amp; Marketing</span></div>
  <div style="display:flex;align-items:center;gap:10px">
    <span style="font-size:10px;font-family:var(--mo);color:var(--tx3);background:var(--bg3);border:1px solid var(--bd);padding:3px 9px;border-radius:4px">first touch</span>
    <div class="ytabs">
      <button class="ybtn on" onclick="setYear(2025,this)">2025</button>
      <button class="ybtn" onclick="setYear(2026,this)">2026</button>
    </div>
  </div>
</header>

<div class="fbar">
